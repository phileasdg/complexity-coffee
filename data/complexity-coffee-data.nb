          "event_time" -> 1764646800000, "location" -> "Virtual Workshop", 
          "image_path" -> "img/general/paint1.jpeg", "tag" -> "Workshop", 
          "description_html" -> 
          "<p>Join us for a hands-on workshop designed to introduce the \
